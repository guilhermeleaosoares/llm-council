{
  "name": "llm-council",
  "private": true,
  "version": "2.0.7",
  "description": "LLM Council - A professional desktop application for AI interaction.",
  "author": {
    "name": "Guilherme Soares",
    "email": "guilhermeleaosoares@gmail.com"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "backend": "cd server && node index.js",
    "electron:dev": "concurrently \"NODE_ENV=development npm run dev\" \"wait-on http://localhost:5173 && unset ELECTRON_RUN_AS_NODE && NODE_ENV=development npx electron electron/main.cjs\"",
    "electron:build": "npm run build && unset ELECTRON_RUN_AS_NODE && electron-builder",
    "server": "concurrently \"npm run dev\" \"npm run backend\""
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@xyflow/react": "^12.10.1",
    "dagre": "^0.8.5",
    "firebase": "^11.1.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.33",
    "lucide-react": "^0.460.0",
    "mermaid": "^11.12.3",
    "pdfjs-dist": "^4.9.155",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "react-zoom-pan-pinch": "^3.7.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "vite": "^6.0.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.guilhermesoares.llmcouncil",
    "productName": "LLM Council",
    "copyright": "Copyright © 2026 Guilherme Soares",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis",
        "msi"
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "guilhermeleaosoares",
      "repo": "llm-council"
    }
  }
}
